# Copy to .env on the server. Never commit real secrets.

NODE_ENV=production
PORT=4000

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Comma-separated browser origins allowed to call the API (Netlify preview + production).
# Example: https://sirva.in,https://www.sirva.in,https://deploy-preview-123--yourapp.netlify.app
CORS_ORIGINS=https://your-production-domain.com

# Set when the app runs behind Nginx/ALB so req.ip and secure cookies behave correctly.
TRUST_PROXY=1

# Existing app secrets (see your team vault)
# SUPABASE_*, RESEND_*, CLOUDINARY_*, etc.

# Cloudinary: required for uploads. CLOUDINARY_CLOUD_NAME is also returned at GET /api/public-config
# so the web app can build image URLs when VITE_CLOUDINARY_CLOUD_NAME is not set on the frontend build.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional. Cloudinary public_id prefix for listing uploads: {root}/listings/{userId}/…
# Default when unset: cirvo. Do not set this to trusted-network unless you intentionally keep the legacy folder.
# CLOUDINARY_LISTINGS_FOLDER_ROOT=cirvo

# Google Static Map preview on listing / composer (marker at coordinates). Set to false to stop Static Maps requests (billing).
# Frontend can also set VITE_GOOGLE_MAPS_STATIC_MAP_ENABLED=false at build time.
# STATIC_MAP_PREVIEW_ENABLED=true
