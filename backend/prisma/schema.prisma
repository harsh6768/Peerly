generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationType {
  COMPANY
  COMMUNITY
  GATED_COMMUNITY
  NETWORK
  OTHER
}

enum MembershipRole {
  MEMBER
  ADMIN
  MODERATOR
}

enum MembershipStatus {
  INVITED
  ACTIVE
  INACTIVE
  BLOCKED
}

enum VerificationBadge {
  NONE
  EMAIL_VERIFIED
  LINKEDIN_VERIFIED
  COMPANY_VERIFIED
  MANUALLY_VERIFIED
}

enum AuthProvider {
  GOOGLE
}

enum AssetProvider {
  CLOUDINARY
  S3
}

enum VerificationType {
  WORK_EMAIL
  LINKEDIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UrgencyLevel {
  IMMEDIATE
  THIS_WEEK
  FLEXIBLE
}

enum ContactMode {
  WHATSAPP
  CALL
  CHAT
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  PAUSED
  ARCHIVED
  FILLED
}

enum ListingType {
  tenant_replacement
  send_request
}

enum PropertyType {
  ROOM
  STUDIO
  APARTMENT
  PG
  HOUSE
}

enum OccupancyType {
  SINGLE
  DOUBLE
  SHARED
}

enum NearbyPlaceType {
  tech_park
  company
}

enum ListingInquiryStatus {
  NEW
  CONTACTED
  SCHEDULED
  CLOSED
  DECLINED
}

enum ListingVisitStatus {
  NONE
  PROPOSED
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum HousingNeedStatus {
  OPEN
  MATCHED
  CLOSED
  ARCHIVED
}

enum TravelerRouteStatus {
  DRAFT
  PUBLISHED
  MATCHED
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum CapacityType {
  DOCUMENTS_ONLY
  SMALL_BAG
  CABIN_LUGGAGE
  CHECK_IN_LUGGAGE
}

enum ShipmentRequestStatus {
  DRAFT
  OPEN
  MATCHED
  IN_TRANSIT
  DELIVERED
  CANCELLED
  EXPIRED
}

enum ItemType {
  DOCUMENTS
  ELECTRONICS
  CLOTHING
  FOOD
  MEDICINE
  OTHER
}

enum ItemSize {
  SMALL
  MEDIUM
  LARGE
}

enum MatchStatus {
  SUGGESTED
  CONTACTED
  ACCEPTED
  REJECTED
  EXPIRED
  COMPLETED
  CANCELLED
}

enum ConversationType {
  LISTING
  SHIPMENT
  SUPPORT
}

enum ConversationStatus {
  ACTIVE
  CLOSED
  BLOCKED
}

enum MessageType {
  TEXT
  SYSTEM
}

enum EntityType {
  USER
  LISTING
  LISTING_INQUIRY
  TRAVELER_ROUTE
  SHIPMENT_REQUEST
  MATCH
  CONVERSATION
  MESSAGE
}

enum ReportStatus {
  OPEN
  REVIEWED
  ACTIONED
  DISMISSED
}

enum ReportReason {
  SPAM
  FAKE_LISTING
  HARASSMENT
  PROHIBITED_ITEM
  OTHER
}

enum TrackingEventType {
  MATCHED
  PICKUP_CONFIRMED
  IN_TRANSIT
  ARRIVED_HANDOFF
  DELIVERED
  ISSUE_REPORTED
}

model User {
  id                          String                    @id @default(cuid())
  fullName                    String
  email                       String                    @unique
  authProvider                AuthProvider              @default(GOOGLE)
  googleSub                   String?                   @unique
  phone                       String?                   @db.VarChar(20)
  avatarUrl                   String?
  homeCity                    String?
  bio                         String?                   @db.Text
  isVerified                  Boolean                   @default(false)
  verificationType            VerificationType?
  workEmail                   String?
  companyName                 String?
  linkedinUrl                 String?
  verificationStatus          VerificationStatus?
  isActive                    Boolean                   @default(true)
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt
  authSessions                AuthSession[]
  workEmailOtps               WorkEmailOtp[]
  memberships                 UserOrganizationMembership[]
  verificationProfile         VerificationProfile?
  ownedListings               Listing[]                 @relation("ListingOwner")
  housingNeeds                HousingNeed[]
  travelerRoutes              TravelerRoute[]
  shipmentRequests            ShipmentRequest[]
  createdConversations        Conversation[]            @relation("ConversationCreator")
  conversationParticipants    ConversationParticipant[]
  sentMessages                Message[]                 @relation("MessageSender")
  listingInquiries            ListingInquiry[]          @relation("InquiryRequester")
  receivedListingInquiries    ListingInquiry[]          @relation("InquiryListingOwner")
  reportsFiled                Report[]                  @relation("ReportReporter")
}

model Organization {
  id                String                       @id @default(cuid())
  name              String
  slug              String                       @unique
  domain            String?
  type              OrganizationType
  city              String?
  isVerifiedNetwork Boolean                      @default(false)
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
  memberships       UserOrganizationMembership[]
  listings          Listing[]
  housingNeeds      HousingNeed[]
  travelerRoutes    TravelerRoute[]
  shipmentRequests  ShipmentRequest[]

  @@index([type, city])
}

model UserOrganizationMembership {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole   @default(MEMBER)
  status         MembershipStatus @default(ACTIVE)
  joinedAt       DateTime         @default(now())
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId, status])
}

model VerificationProfile {
  id                   String            @id @default(cuid())
  userId               String            @unique
  companyEmailVerified Boolean           @default(false)
  linkedinVerified     Boolean           @default(false)
  governmentIdVerified Boolean           @default(false)
  verificationBadge    VerificationBadge @default(NONE)
  trustScore           Int               @default(0)
  lastVerifiedAt       DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthSession {
  id           String       @id @default(cuid())
  userId       String
  sessionToken String       @unique
  provider     AuthProvider @default(GOOGLE)
  expiresAt    DateTime
  lastSeenAt   DateTime     @default(now())
  createdAt    DateTime     @default(now())
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model WorkEmailOtp {
  id           String   @id @default(cuid())
  userId       String
  workEmail    String
  otpHash      String
  attemptCount Int      @default(0)
  maxAttempts  Int      @default(3)
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([workEmail, createdAt])
}

model Listing {
  id             String           @id @default(cuid())
  ownerUserId    String
  organizationId String?
  type           ListingType      @default(tenant_replacement)
  title          String
  description    String?          @db.Text
  city           String?
  locality       String?
  locationName   String?          @db.Text
  latitude       Float?
  longitude      Float?
  fromCity       String?
  toCity         String?
  itemType       ItemType?
  requiredDate   DateTime?
  contactPhone   String?          @db.VarChar(20)
  rentAmount     Int?
  depositAmount  Int?
  maintenanceAmount Int?
  miscCharges    String?          @db.Text
  amenities      String[]         @default([])
  propertyType   PropertyType?
  occupancyType  OccupancyType?
  moveInDate     DateTime?
  moveOutDate    DateTime?
  urgencyLevel   UrgencyLevel     @default(FLEXIBLE)
  contactMode    ContactMode      @default(WHATSAPP)
  status         ListingStatus    @default(DRAFT)
  isBoosted      Boolean          @default(false)
  brokerAllowed  Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  owner          User             @relation("ListingOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  images         ListingImage[]
  nearbyPlaces   ListingNearby[]
  inquiries      ListingInquiry[]

  @@index([organizationId, status])
  @@index([city, locality, status])
  @@index([moveInDate, urgencyLevel])
  @@index([type, status])
}

model ListingNearby {
  id        String          @id @default(cuid())
  listingId String
  name      String          @db.VarChar(120)
  type      NearbyPlaceType
  createdAt DateTime        @default(now())
  listing   Listing         @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, name])
  @@index([listingId, createdAt])
  @@index([name])
}

model ListingImage {
  id              String        @id @default(cuid())
  listingId       String
  assetProvider   AssetProvider @default(CLOUDINARY)
  providerAssetId String
  imageUrl        String
  thumbnailUrl    String
  detailUrl       String
  width           Int?
  height          Int?
  bytes           Int?
  isCover         Boolean       @default(false)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  listing         Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, sortOrder])
  @@index([listingId, isCover])
}

model HousingNeed {
  id                   String            @id @default(cuid())
  userId               String
  organizationId       String?
  city                 String
  locality             String?
  preferredPropertyType PropertyType
  preferredOccupancy   OccupancyType
  maxRentAmount        Int?
  moveInDate           DateTime
  urgencyLevel         UrgencyLevel      @default(FLEXIBLE)
  preferredContactMode ContactMode       @default(WHATSAPP)
  notes                String?           @db.Text
  status               HousingNeedStatus @default(OPEN)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  user                 User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization         Organization?     @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([city, locality, status])
  @@index([moveInDate, urgencyLevel])
}

model ListingInquiry {
  id                  String               @id @default(cuid())
  listingId           String
  requesterUserId     String
  listingOwnerUserId  String
  message             String?              @db.Text
  ownerNotes          String?              @db.Text
  budgetAmount        Int?
  preferredMoveInDate DateTime?
  preferredOccupancy  OccupancyType?
  preferredVisitAt    DateTime?
  preferredVisitNote  String?              @db.Text
  scheduledVisitAt    DateTime?
  scheduledVisitNote  String?              @db.Text
  visitStatus         ListingVisitStatus   @default(NONE)
  visitConfirmedAt    DateTime?
  visitCancelledAt    DateTime?
  visitCompletedAt    DateTime?
  status              ListingInquiryStatus @default(NEW)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  listing             Listing              @relation(fields: [listingId], references: [id], onDelete: Cascade)
  requester           User                 @relation("InquiryRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  listingOwner        User                 @relation("InquiryListingOwner", fields: [listingOwnerUserId], references: [id], onDelete: Cascade)
  conversation        Conversation?

  @@index([listingId, status])
  @@index([requesterUserId, createdAt])
  @@index([listingOwnerUserId, status, createdAt])
}

model TravelerRoute {
  id               String              @id @default(cuid())
  userId           String
  organizationId   String?
  sourceCity       String
  sourceArea       String?
  destinationCity  String
  destinationArea  String?
  travelDate       DateTime
  travelTimeWindow String?
  capacityType     CapacityType
  capacityNotes    String?             @db.Text
  allowedItemTypes ItemType[]
  status           TravelerRouteStatus @default(DRAFT)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization     Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  matches          Match[]

  @@index([organizationId, status])
  @@index([sourceCity, destinationCity, travelDate, status])
}

model ShipmentRequest {
  id                   String                @id @default(cuid())
  userId               String
  organizationId       String?
  sourceCity           String
  sourceArea           String?
  destinationCity      String
  destinationArea      String?
  requiredBy           DateTime
  itemType             ItemType
  itemSize             ItemSize
  itemWeightKg         Decimal?              @db.Decimal(5, 2)
  specialHandlingNotes String?               @db.Text
  urgencyLevel         UrgencyLevel          @default(FLEXIBLE)
  quotedBudget         Int?
  prohibitedItemConfirmed Boolean            @default(false)
  status               ShipmentRequestStatus @default(OPEN)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization         Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  matches              Match[]
  trackingEvents       ParcelTrackingEvent[]

  @@index([organizationId, status])
  @@index([sourceCity, destinationCity, requiredBy, status])
}

model Match {
  id                String          @id @default(cuid())
  travelerRouteId   String
  shipmentRequestId String
  score             Decimal?        @db.Decimal(5, 2)
  status            MatchStatus     @default(SUGGESTED)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  travelerRoute     TravelerRoute   @relation(fields: [travelerRouteId], references: [id], onDelete: Cascade)
  shipmentRequest   ShipmentRequest @relation(fields: [shipmentRequestId], references: [id], onDelete: Cascade)
  conversation      Conversation?
  trackingEvents    ParcelTrackingEvent[]

  @@unique([travelerRouteId, shipmentRequestId])
  @@index([status, createdAt])
}

model Conversation {
  id              String              @id @default(cuid())
  conversationType ConversationType
  status          ConversationStatus  @default(ACTIVE)
  createdByUserId String
  listingInquiryId String?            @unique
  matchId         String?             @unique
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  createdBy       User                @relation("ConversationCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  listingInquiry  ListingInquiry?     @relation(fields: [listingInquiryId], references: [id], onDelete: SetNull)
  match           Match?              @relation(fields: [matchId], references: [id], onDelete: SetNull)
  participants    ConversationParticipant[]
  messages        Message[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderUserId   String?
  body           String       @db.Text
  messageType    MessageType  @default(TEXT)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User?        @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
}

model Report {
  id               String       @id @default(cuid())
  reportedByUserId String
  entityType       EntityType
  entityId         String
  reason           ReportReason
  notes            String?      @db.Text
  status           ReportStatus @default(OPEN)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  reportedBy       User         @relation("ReportReporter", fields: [reportedByUserId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId, status])
}

model ParcelTrackingEvent {
  id                String            @id @default(cuid())
  shipmentRequestId String
  matchId           String?
  eventType         TrackingEventType
  eventLabel        String
  eventLocation     String?
  notes             String?           @db.Text
  source            String?
  eventTime         DateTime
  createdAt         DateTime          @default(now())
  shipmentRequest   ShipmentRequest   @relation(fields: [shipmentRequestId], references: [id], onDelete: Cascade)
  match             Match?            @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([shipmentRequestId, eventTime])
  @@index([matchId, eventTime])
}
